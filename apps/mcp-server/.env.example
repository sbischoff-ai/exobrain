APP_ENV=local
LOG_LEVEL=DEBUG
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8090
WEB_SEARCH_PROVIDER=auto
ENABLED_TOOL_CATEGORIES=utility,knowledge,web
ENABLE_UTILITY_TOOLS=false
ENABLE_WEB_TOOLS=true
ENABLE_KNOWLEDGE_TOOLS=true
# Required when WEB_SEARCH_PROVIDER resolves to tavily.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
